<Window x:Class="LOLInfo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:utils="clr-namespace:LOLInfo.Utils"
        xmlns:props="clr-namespace:LOLInfo.Properties"
        xmlns:vm="clr-namespace:LOLInfo.ViewModels"
        mc:Ignorable="d"
        Title="LolInfo" Height="600" Width="1000">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <TabControl>
        <!-- ── Onglet Champions (navigation liste → détail inchangée) ──────── -->
        <TabItem Header="{x:Static props:Resources.Tab_Champions}">
            <Frame Content="{Binding CurrentPage}" NavigationUIVisibility="Hidden" />
        </TabItem>

        <!-- ── Onglet Objets ───────────────────────────────────────────────── -->
        <TabItem Header="{x:Static props:Resources.Tab_Items}">
            <Grid DataContext="{Binding Items}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" MinWidth="260" />
                </Grid.ColumnDefinitions>

                <!-- Liste des objets (recherche + grille d'icônes) -->
                <DockPanel Grid.Column="0" Margin="8">
                    <Border DockPanel.Dock="Top" Background="#F5F5F5" BorderBrush="#E0E0E0"
                            BorderThickness="1" CornerRadius="3" Padding="8,5" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBox Width="220" VerticalAlignment="Center"
                                     Tag="{x:Static props:Resources.ItemPage_Search}"
                                     Text="{Binding NameFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ItemsView}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ItemViewModel}">
                                    <Button Click="ItemButton_OnClick"
                                            ToolTip="{Binding Name}"
                                            Background="Transparent" BorderThickness="1"
                                            BorderBrush="#DDD" Padding="2" Margin="3" Cursor="Hand">
                                        <Image utils:CachedImage.Kind="{x:Static utils:ImageConstant.ITEM}"
                                               utils:CachedImage.SourcePath="{Binding ImagePath}"
                                               Width="40" Height="40" />
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>

                <!-- Panneau de détail de l'objet sélectionné -->
                <Border Grid.Column="1" Background="#F7F7F7" BorderBrush="#E0E0E0"
                        BorderThickness="1,0,0,0" Padding="14"
                        DataContext="{Binding SelectedItem}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- En-tête : icône + nom + coût -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Image utils:CachedImage.Kind="{x:Static utils:ImageConstant.ITEM}"
                                       utils:CachedImage.SourcePath="{Binding ImagePath}"
                                       Width="48" Height="48" Margin="0,0,10,0" VerticalAlignment="Top" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"
                                               TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{x:Static props:Resources.ItemPage_Cost}"
                                                   Foreground="#777" Margin="0,0,4,0" />
                                        <TextBlock Text="{Binding Gold}" FontWeight="SemiBold" Foreground="#C8941E" />
                                        <TextBlock Text=" 🪙" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- Stats -->
                            <ItemsControl ItemsSource="{Binding Stats}"
                                          Visibility="{Binding HasStats, Converter={StaticResource BoolToVis}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ChampionStatRow}">
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Value}"
                                                       FontWeight="SemiBold" Foreground="#1A7F37" />
                                            <TextBlock Grid.Column="1" Text="{Binding Label}" Foreground="#444" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Effets -->
                            <TextBlock Text="{x:Static props:Resources.ItemPage_Effects}"
                                       FontWeight="SemiBold" Margin="0,12,0,4"
                                       Visibility="{Binding HasEffects, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="{Binding Effects}" TextWrapping="Wrap" Foreground="#444"
                                       FontSize="12"
                                       Visibility="{Binding HasEffects, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
