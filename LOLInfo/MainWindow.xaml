<Window x:Class="LOLInfo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:props="clr-namespace:LOLInfo.Properties"
        xmlns:views="clr-namespace:LOLInfo.Views"
        xmlns:vm="clr-namespace:LOLInfo.ViewModels"
        mc:Ignorable="d"
        Title="LolInfo" Height="600" Width="1000">
    <Window.Resources>
        <!-- Élément du sélecteur de langue : drapeau (vectoriel) + endonyme -->
        <DataTemplate x:Key="LanguageItemTemplate" DataType="{x:Type vm:LanguageOption}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Grid Width="22" Height="14" Margin="0,0,8,0" ClipToBounds="True" SnapsToDevicePixels="True">
                    <!-- France : tricolore -->
                    <Grid x:Name="FlagFr" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Fill="#0055A4" />
                        <Rectangle Grid.Column="1" Fill="#FFFFFF" />
                        <Rectangle Grid.Column="2" Fill="#EF4135" />
                    </Grid>
                    <!-- Royaume-Uni (anglais) : Union Jack -->
                    <Grid x:Name="FlagEn" Visibility="Collapsed" ClipToBounds="True">
                        <Rectangle Fill="#012169" />
                        <Rectangle Fill="#FFFFFF" Width="27" Height="5" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform><RotateTransform Angle="32" /></Rectangle.RenderTransform>
                        </Rectangle>
                        <Rectangle Fill="#FFFFFF" Width="27" Height="5" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform><RotateTransform Angle="-32" /></Rectangle.RenderTransform>
                        </Rectangle>
                        <Rectangle Fill="#C8102E" Width="27" Height="2" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform><RotateTransform Angle="32" /></Rectangle.RenderTransform>
                        </Rectangle>
                        <Rectangle Fill="#C8102E" Width="27" Height="2" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform><RotateTransform Angle="-32" /></Rectangle.RenderTransform>
                        </Rectangle>
                        <Rectangle Fill="#FFFFFF" Width="6" HorizontalAlignment="Center" />
                        <Rectangle Fill="#FFFFFF" Height="6" VerticalAlignment="Center" />
                        <Rectangle Fill="#C8102E" Width="3.5" HorizontalAlignment="Center" />
                        <Rectangle Fill="#C8102E" Height="3.5" VerticalAlignment="Center" />
                    </Grid>
                </Grid>
                <TextBlock Text="{Binding NativeName}" VerticalAlignment="Center" />
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Code}" Value="fr">
                    <Setter TargetName="FlagFr" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Code}" Value="en">
                    <Setter TargetName="FlagEn" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <TabControl>
            <!-- ── Onglet Champions (navigation liste → détail inchangée) ──────── -->
            <TabItem Header="{x:Static props:Resources.Tab_Champions}">
                <Frame Content="{Binding CurrentPage}" NavigationUIVisibility="Hidden" />
            </TabItem>

            <!-- ── Onglet Objets : navigateur (gauche) + détail (droite) ───────── -->
            <TabItem Header="{x:Static props:Resources.Tab_Items}">
                <Grid DataContext="{Binding Items}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" MinWidth="260" />
                    </Grid.ColumnDefinitions>

                    <views:ItemBrowserControl Grid.Column="0" Margin="8" />

                    <Border Grid.Column="1" Background="#F7F7F7" BorderBrush="#E0E0E0"
                            BorderThickness="1,0,0,0" Padding="14">
                        <views:ItemDetailControl DataContext="{Binding SelectedItem}" />
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Sélecteur de langue (haut-droite) : drapeau + endonyme. Le changement
             persiste la langue et propose un redémarrage pour l'appliquer. -->
        <ComboBox x:Name="LanguageSelector"
                  HorizontalAlignment="Right" VerticalAlignment="Top"
                  Margin="0,3,8,0" MinWidth="130" Panel.ZIndex="10"
                  ItemsSource="{Binding Languages}"
                  ItemTemplate="{StaticResource LanguageItemTemplate}"
                  SelectedValuePath="Code"
                  SelectedValue="{Binding CurrentLanguageCode, Mode=OneWay}"
                  SelectionChanged="LanguageSelector_SelectionChanged"
                  ToolTip="{x:Static props:Resources.Language_Tooltip}" />
    </Grid>
</Window>
