                <Setter.Value>
                    <ImageBrush ImageSource="pack://application:,,,/YourAssemblyName;component/Resources/bg/A6000000.png" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsEnabled}" Value="True">
                    <Setter Property="Background" Value="#A6000000" />
                </DataTrigger>
            </Style.Triggers>
