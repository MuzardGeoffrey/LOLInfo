<Page x:Class="LOLInfo.Views.DetailChampionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:utils="clr-namespace:LOLInfo.Utils"
      xmlns:vm="clr-namespace:LOLInfo.ViewModels"
      xmlns:props="clr-namespace:LOLInfo.Properties"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="900"
      Title="DetailChampionPage">

    <Page.Resources>
        <!--
            BooleanToVisibilityConverter est fourni par WPF.
            Il transforme true → Visible, false → Collapsed.
            Utilisé pour masquer les sections Stats et Leveltip du passif.
        -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!--
            DataTemplate unique pour SpellViewModel.
            Utilisé par les 5 onglets (Passif, Q, W, E, R).
            Modifier ici pour changer l'apparence de TOUS les sorts à la fois.
        -->
        <DataTemplate x:Key="SpellTemplate" DataType="{x:Type vm:SpellViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                <StackPanel>

                    <!-- ── En-tête : icône + nom + description ─────────── -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--
                            L'icône utilise un MultiBinding impossible à faire ici.
                            On utilise un style avec DataTrigger sur IsPassive
                            pour choisir le bon ConverterParameter.
                            Alternative simple : deux Image superposées via Trigger.
                        -->
                        <Border Grid.Column="0"
                                Width="72" Height="72"
                                CornerRadius="6"
                                BorderBrush="#444"
                                BorderThickness="1">
                            <!--
                                Le dossier CDN diffère selon le type : le passif est dans
                                /img/passive/, les sorts actifs dans /img/spell/. Kind suit
                                donc SpellViewModel.ImageKind (basé sur IsPassive).
                            -->
                            <Image utils:CachedImage.Kind="{Binding ImageKind}"
                                   utils:CachedImage.SourcePath="{Binding IconPath}" />
                        </Border>

                        <!-- Nom + description -->
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6" />
                            <TextBlock Text="{Binding Description}"
                                       FontSize="12"
                                       Foreground="#444"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                    <!-- ── Tableau de progression par niveau ─────────────── -->
                    <!--
                        Visibility liée à HasStats (false pour le passif et les placeholders).

                        Structure du tableau :
                          Col 0 (140px) : libellé (⏱ Recharge, 💧 Coût, 🎯 Portée)
                          Col 1 (*)     : UniformGrid 1 ligne avec les valeurs par rang

                        LevelHeaders  → en-têtes "Niv 1" … "Niv N"
                        StatRows      → lignes de données (SpellStatRow)
                        UniformGrid   → adapte les colonnes au nombre de valeurs
                                        (3 pour R, 5 pour Q/W/E, 1 si valeur constante)
                    -->
                    <Border Visibility="{Binding HasStats, Converter={StaticResource BoolToVis}}"
                            Background="#F0F0F0"
                            CornerRadius="4"
                            Padding="12,8"
                            Margin="0,0,0,12">
                        <StackPanel>

                            <!-- Ligne d'en-têtes "Niv 1" … "Niv N" -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" />

                                <ItemsControl Grid.Column="1"
                                              ItemsSource="{Binding LevelHeaders}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       TextAlignment="Center"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="#888" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <Separator Margin="0,0,0,4" />

                            <!-- Lignes de stats -->
                            <ItemsControl ItemsSource="{Binding StatRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:SpellStatRow}">
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Label}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />

                                            <ItemsControl Grid.Column="1"
                                                          ItemsSource="{Binding Values}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Rows="1" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   TextAlignment="Center"
                                                                   FontSize="12"
                                                                   VerticalAlignment="Center" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>

                    <!-- ── Gain par niveau (Leveltip) ─────────────────────── -->
                    <!--
                        Visibility liée à HasLeveltip (false si liste vide).
                        ItemsControl itère sur LeveltipRows.
                        Chaque ligne = un LeveltipRowViewModel : Label + Effect.
                    -->
                    <StackPanel Visibility="{Binding HasLeveltip, Converter={StaticResource BoolToVis}}">

                        <TextBlock Text="{x:Static props:Resources.Detail_LevelGain}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />

                        <ItemsControl ItemsSource="{Binding LeveltipRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:LeveltipRowViewModel}">
                                    <!--
                                        Grille à deux colonnes :
                                        - Col 0 (fixe 180px) : libellé de la stat
                                        - Col 1 (*)          : valeurs par niveau
                                        La largeur fixe aligne tous les labels verticalement.
                                    -->
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Label}"
                                                   FontSize="12"
                                                   Foreground="#555"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Effect}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>

                    <!-- ── Formules de scaling CDragon ──────────────────────── -->
                    <!--
                        Visibility liée à HasFormulas (false si CDragon n'a pas retourné
                        de données, ou si le sort n'a pas de calculs).
                        Chaque ligne = FormulaRowViewModel : Label (nom calcul) + Formula.
                    -->
                    <StackPanel Visibility="{Binding HasFormulas, Converter={StaticResource BoolToVis}}"
                                Margin="0,8,0,0">

                        <TextBlock Text="{x:Static props:Resources.Detail_Formulas}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />

                        <ItemsControl ItemsSource="{Binding FormulaRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:FormulaRowViewModel}">
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Label}"
                                                   FontSize="12"
                                                   Foreground="#555"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Formula}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1A1A8C"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

    </Page.Resources>

    <!-- ── Layout principal ──────────────────────────────────────────────── -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- En-tête champion -->
            <RowDefinition Height="*" />
            <!-- Onglets -->
        </Grid.RowDefinitions>

        <!-- ── En-tête : icône + nom + titre ──────────────────────────── -->
        <Border Grid.Row="0"
                Background="#1A1A2E"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       utils:CachedImage.Kind="{x:Static utils:ImageConstant.MINIATURE}"
                       utils:CachedImage.SourcePath="{Binding Champion.Image.Full}"
                       Width="56" Height="56"
                       Margin="0,0,12,0" />

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Champion.Name}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="White" />
                    <TextBlock Text="{Binding Champion.Title}"
                               FontSize="13"
                               Foreground="#AAAAAA" />
                </StackPanel>

                <Button Grid.Column="2"
                        x:Name="BackButton"
                        Content="{x:Static props:Resources.Detail_Back}"
                        Click="BackButton_OnClick"
                        VerticalAlignment="Center"
                        Padding="12,6"
                        Background="#3A3A5C"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand" />
            </Grid>
        </Border>

        <!-- ── Onglets ─────────────────────────────────────────────────── -->
        <TabControl Grid.Row="1" Margin="0">
            <TabItem Header="{x:Static props:Resources.Detail_Tab_Spells}">
                <!--
                    Onglet Sorts : TabControl secondaire avec onglets à gauche.
                    Chaque onglet est lié à un SpellViewModel de la liste Spells.
                    Le contenu est rendu via SpellTemplate (DataTemplate unique).
                -->
                <TabControl TabStripPlacement="Left">
                    <TabControl.Resources>
                        <!-- Rotation des en-têtes d'onglets latéraux -->
                        <Style TargetType="TabItem">
                            <Setter Property="HeaderTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <ContentPresenter Content="{TemplateBinding Content}">
                                            <ContentPresenter.LayoutTransform>
                                                <RotateTransform Angle="270" />
                                            </ContentPresenter.LayoutTransform>
                                        </ContentPresenter>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Padding" Value="8,4" />
                            <Setter Property="FontSize" Value="12" />
                        </Style>
                    </TabControl.Resources>

                    <!--
                        Chaque TabItem est lié à un item de Spells via DataContext.
                        L'en-tête affiche Key ("Passif", "Q", "W", "E", "R").
                        Le contenu utilise ContentTemplate="{StaticResource SpellTemplate}"
                        qui est le DataTemplate unique défini dans Page.Resources.
                    -->
                    <!--
                        DataContext est déjà le SpellViewModel (Spells[N]).
                        Header doit donc binder sur Key directement,
                        pas sur Spells[N].Key (qui cherche Spells sur SpellViewModel).
                    -->
                    <TabItem Header="{Binding Key}"
                             DataContext="{Binding Spells[0]}"
                             ContentTemplate="{StaticResource SpellTemplate}"
                             Content="{Binding}" />

                    <TabItem Header="{Binding Key}"
                             DataContext="{Binding Spells[1]}"
                             ContentTemplate="{StaticResource SpellTemplate}"
                             Content="{Binding}" />

                    <TabItem Header="{Binding Key}"
                             DataContext="{Binding Spells[2]}"
                             ContentTemplate="{StaticResource SpellTemplate}"
                             Content="{Binding}" />

                    <TabItem Header="{Binding Key}"
                             DataContext="{Binding Spells[3]}"
                             ContentTemplate="{StaticResource SpellTemplate}"
                             Content="{Binding}" />

                    <TabItem Header="{Binding Key}"
                             DataContext="{Binding Spells[4]}"
                             ContentTemplate="{StaticResource SpellTemplate}"
                             Content="{Binding}" />

                </TabControl>
            </TabItem>

            <TabItem Header="{x:Static props:Resources.Detail_Tab_General}">
                <Grid Background="#F5F5F5" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />  <!-- Lore -->
                        <RowDefinition Height="*" />     <!-- Carrousel de skins -->
                        <RowDefinition Height="Auto" />  <!-- Nom du skin -->
                        <RowDefinition Height="Auto" />  <!-- Boutons -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding Champion.Blurb}"
                               TextWrapping="Wrap" FontSize="13" Foreground="#333"
                               Margin="0,0,0,12" />

                    <!-- ── Carrousel : aperçu précédent · skin courant · aperçu suivant ── -->
                    <Grid Grid.Row="1"
                          Visibility="{Binding HasSkins, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Aperçu précédent (réduit + estompé) -->
                        <Image Grid.Column="0"
                               Opacity="0.4"
                               Margin="0,16,8,16"
                               utils:CachedImage.Kind="{x:Static utils:ImageConstant.SKIN}"
                               utils:CachedImage.SourcePath="{Binding PreviousSkin.SkinPath}"
                               VerticalAlignment="Center" />

                        <!-- Skin courant -->
                        <Image Grid.Column="1"
                               utils:CachedImage.Kind="{x:Static utils:ImageConstant.SKIN}"
                               utils:CachedImage.SourcePath="{Binding SelectedSkin.SkinPath}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />

                        <!-- Aperçu suivant (réduit + estompé) -->
                        <Image Grid.Column="2"
                               Opacity="0.4"
                               Margin="8,16,0,16"
                               utils:CachedImage.Kind="{x:Static utils:ImageConstant.SKIN}"
                               utils:CachedImage.SourcePath="{Binding NextSkin.SkinPath}"
                               VerticalAlignment="Center" />
                    </Grid>

                    <!-- Nom du skin + badge chromas -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0"
                                Visibility="{Binding HasSkins, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding SelectedSkin.DisplayName}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="#333" VerticalAlignment="Center" />

                        <!-- Affiché seulement si le skin courant a des chromas -->
                        <Border Margin="8,0,0,0" Padding="6,2" CornerRadius="3"
                                Background="#E8E0F5" VerticalAlignment="Center"
                                Visibility="{Binding SelectedSkin.HasChromas, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{x:Static props:Resources.Skin_ChromasAvailable}"
                                       FontSize="11" Foreground="#5B3FA0" />
                        </Border>
                    </StackPanel>

                    <!-- Navigation -->
                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0"
                                Visibility="{Binding HasSkins, Converter={StaticResource BoolToVis}}">
                        <Button x:Name="previousButton"
                                Content="{x:Static props:Resources.Previous}"
                                Click="PreviousSkinButton_OnClick"
                                Padding="12,6" Margin="0,0,8,0" Cursor="Hand" />
                        <Button x:Name="nextButton"
                                Content="{x:Static props:Resources.Next}"
                                Click="NextSkinButton_OnClick"
                                Padding="12,6" Cursor="Hand" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="{x:Static props:Resources.Detail_Tab_Stats}">
                <Grid Background="#F5F5F5" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />  <!-- Sélecteur de niveau -->
                        <RowDefinition Height="*" />     <!-- Liste des stats -->
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,0,14">
                        <TextBlock Text="{x:Static props:Resources.StatPage_Level}"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox Width="70"
                                  ItemsSource="{Binding Levels}"
                                  SelectedItem="{Binding SelectedLevel, Mode=TwoWay}" />
                    </StackPanel>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding ChampionStats}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ChampionStatRow}">
                                <Border Padding="0,4" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                   FontSize="13" Foreground="#555" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding Value}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#1A1A2E" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Page>
