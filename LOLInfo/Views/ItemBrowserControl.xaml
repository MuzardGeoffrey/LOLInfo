<UserControl x:Class="LOLInfo.Views.ItemBrowserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:utils="clr-namespace:LOLInfo.Utils"
             xmlns:props="clr-namespace:LOLInfo.Properties"
             xmlns:views="clr-namespace:LOLInfo.Views"
             xmlns:vm="clr-namespace:LOLInfo.ViewModels"
             xmlns:models="clr-namespace:LOLInfo.Models"
             mc:Ignorable="d" d:DesignHeight="500" d:DesignWidth="600">
    <UserControl.Resources>
        <utils:EnumToBoolConverter x:Key="EnumToBool" />

        <Style x:Key="ItemFilterLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin"            Value="0,0,6,0" />
            <Setter Property="FontSize"          Value="12" />
            <Setter Property="Foreground"        Value="#555555" />
        </Style>

        <Style x:Key="ItemFilterRadio" TargetType="RadioButton">
            <Setter Property="Margin"            Value="0,0,6,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize"          Value="12" />
            <Setter Property="Cursor"            Value="Hand" />
        </Style>

        <Style x:Key="ItemFilterCheck" TargetType="CheckBox">
            <Setter Property="Margin"            Value="0,2,12,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize"          Value="12" />
            <Setter Property="Cursor"            Value="Hand" />
        </Style>
    </UserControl.Resources>

    <!-- DataContext attendu : IItemsViewModel -->
    <DockPanel>
        <!-- Barre d'outils : recherche + mode de jeu + tri -->
        <Border DockPanel.Dock="Top" Background="#F5F5F5" BorderBrush="#E0E0E0"
                BorderThickness="1" CornerRadius="3" Padding="8,5" Margin="0,0,0,8">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="🔍" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <views:AutoCompleteBox Width="200" VerticalAlignment="Center"
                                           Text="{Binding NameFilter, Mode=TwoWay}"
                                           ItemsSource="{Binding SearchSuggestions}"
                                           TextMemberPath="Name"
                                           Placeholder="{x:Static props:Resources.ItemPage_Search}" />
                </StackPanel>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,0,12,0" />

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="{x:Static props:Resources.Toolbar_GameMode}" Style="{StaticResource ItemFilterLabel}" />
                    <RadioButton Content="{x:Static props:Resources.Filter_All}" Style="{StaticResource ItemFilterRadio}" GroupName="GameModeFilter"
                                 IsChecked="{Binding SelectedGameMode, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool},
                                             ConverterParameter={x:Static models:GameModeFilter.Tous}}" />
                    <RadioButton Content="{x:Static props:Resources.GameMode_NormalRanked}" Style="{StaticResource ItemFilterRadio}" GroupName="GameModeFilter"
                                 IsChecked="{Binding SelectedGameMode, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool},
                                             ConverterParameter={x:Static models:GameModeFilter.NormalClasse}}" />
                    <RadioButton Content="{x:Static props:Resources.GameMode_Aram}" Style="{StaticResource ItemFilterRadio}" GroupName="GameModeFilter"
                                 IsChecked="{Binding SelectedGameMode, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool},
                                             ConverterParameter={x:Static models:GameModeFilter.Aram}}" />
                    <RadioButton Content="{x:Static props:Resources.GameMode_Arena}" Style="{StaticResource ItemFilterRadio}" GroupName="GameModeFilter"
                                 IsChecked="{Binding SelectedGameMode, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool},
                                             ConverterParameter={x:Static models:GameModeFilter.Arena}}" />
                </StackPanel>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,0,12,0" />

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static props:Resources.Toolbar_Sort}" Style="{StaticResource ItemFilterLabel}" />
                    <ComboBox Width="130" VerticalAlignment="Center"
                              ItemsSource="{Binding SortOptions}"
                              SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}"
                              DisplayMemberPath="Label" />
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Filtre par statistique (multi-sélection, combiné en ET) -->
        <Border DockPanel.Dock="Top" Background="#FAFAFA" BorderBrush="#E0E0E0"
                BorderThickness="1" CornerRadius="3" Padding="8,5" Margin="0,0,0,8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                           Text="{x:Static props:Resources.Toolbar_StatFilter}"
                           Style="{StaticResource ItemFilterLabel}" />
                <ItemsControl ItemsSource="{Binding StatFilters}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:FilterItemViewModel}">
                            <CheckBox Content="{Binding Label}"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Style="{StaticResource ItemFilterCheck}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ItemsView}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ItemViewModel}">
                        <Button Click="ItemButton_OnClick"
                                ToolTip="{Binding Name}"
                                Background="Transparent" BorderThickness="1"
                                BorderBrush="#DDD" Padding="2" Margin="3" Cursor="Hand">
                            <Image utils:CachedImage.Kind="{x:Static utils:ImageConstant.ITEM}"
                                   utils:CachedImage.SourcePath="{Binding ImagePath}"
                                   Width="40" Height="40" />
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
